## Backend environment example (DO NOT put secrets in git)
## Copy to `.env` and fill values.

PORT=5000
JWT_SECRET=change_me
MONGO_URI=mongodb+srv://<user>:<password>@<cluster-host>/<dbName>?retryWrites=true&w=majority

## ZEGOCLOUD configuration
## Create credentials in ZEGOCLOUD Console
ZEGO_APP_ID=
ZEGO_SERVER_SECRET=
## Optional token TTL in seconds
ZEGO_TOKEN_TTL_SEC=3600
## Optional external meeting page URL (should accept roomID query parameter)
ZEGO_MEETING_BASE_URL=

## Public web app URL (used in password reset emails; no trailing slash)
FRONTEND_PUBLIC_URL=http://localhost:5173

## Optional critical alert settings
CRITICAL_GLUCOSE_THRESHOLD=250
## Optional SMS webhook endpoint. If set, backend POSTs: { to, message }
SMS_WEBHOOK_URL=

## Minimum glucose history points before 6-24h LSTM forecast is invoked
MIN_GLUCOSE_FORECAST_POINTS=12
